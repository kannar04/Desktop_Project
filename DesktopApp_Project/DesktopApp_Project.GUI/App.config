<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <connectionStrings>
        <add name="QuanLyIeltsDb"
             connectionString="Data Source=MSI\SQLEXPRESS;Initial Catalog=QuanLyLopIELTS;Integrated Security=True;"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
    <appSettings>
        <!-- VNPAY Sandbox - demo only, replace before any real use -->
        <add key="vnpay:PayUrl" value="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html" />
        <add key="vnpay:TmnCode" value="YOUR_VNPAY_SANDBOX_TMN_CODE" />
        <add key="vnpay:HashSecret" value="YOUR_VNPAY_SANDBOX_HASH_SECRET" />
        <add key="vnpay:ReturnUrl" value="http://localhost/vnpay-return" />

        <!-- Gmail SMTP - use App Password, not account password -->
        <add key="smtp:Host" value="smtp.gmail.com" />
        <add key="smtp:Port" value="587" />
        <add key="smtp:SenderAccount" value="your_gmail@gmail.com" />
        <add key="smtp:AppPassword" value="your_gmail_app_password" />
        <add key="smtp:SenderAddress" value="your_gmail@gmail.com" />
    </appSettings>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
</configuration>
